generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  passwordHash String
  name         String
  phone        String?
  role         Role       @default(CUSTOMER)
  orders       Order[]
  questions    Question[]
  createdAt    DateTime   @default(now())
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  READY
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum OrderType {
  DINE_IN
  TAKEOUT
}

model Order {
  id          Int         @id @default(autoincrement())
  user        User        @relation(fields: [userId], references: [id])
  userId      Int
  status      OrderStatus @default(PENDING)
  orderType   OrderType   @default(TAKEOUT)
  totalPrice  Int
  pickupTime  DateTime?
  items       OrderItem[]
  payment     Payment?
  createdAt   DateTime    @default(now())
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  order           Order    @relation(fields: [orderId], references: [id])
  orderId         Int
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId      Int
  name            String
  quantity        Int
  unitPrice       Int
  selectedOptions Json
}

model Payment {
  id              Int           @id @default(autoincrement())
  order           Order         @relation(fields: [orderId], references: [id])
  orderId         Int           @unique
  method          String
  amount          Int
  status          PaymentStatus @default(PENDING)
  pgTransactionId String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  sortOrder Int        @default(0)
  menuItems MenuItem[]
  createdAt DateTime   @default(now())
}

model MenuItem {
  id           Int           @id @default(autoincrement())
  category     Category      @relation(fields: [categoryId], references: [id])
  categoryId   Int
  name         String
  description  String?
  price        Int
  imageUrl     String?
  isSoldOut    Boolean       @default(false)
  isAvailable  Boolean       @default(true)
  optionGroups OptionGroup[]
  orderItems   OrderItem[]
  createdAt    DateTime      @default(now())
}

model OptionGroup {
  id           Int            @id @default(autoincrement())
  menuItem     MenuItem       @relation(fields: [menuItemId], references: [id])
  menuItemId   Int
  name         String
  isRequired   Boolean        @default(false)
  minSelect    Int            @default(0)
  maxSelect    Int            @default(1)
  optionChoices OptionChoice[]
}

model OptionChoice {
  id            Int         @id @default(autoincrement())
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id])
  optionGroupId Int
  name          String
  extraPrice    Int         @default(0)
}

model Question {
  id         Int       @id @default(autoincrement())
  user       User      @relation(fields: [userId], references: [id])
  userId     Int
  title      String
  content    String
  answer     String?
  answeredAt DateTime?
  createdAt  DateTime  @default(now())
}

enum SeatStatus {
  AVAILABLE
  FULL
}

/** 매장 좌석 현황 (싱글턴, 항상 id=1 한 행만 사용) */
model StoreStatus {
  id         Int        @id @default(autoincrement())
  seatStatus SeatStatus @default(AVAILABLE)
  updatedAt  DateTime   @updatedAt
}

# Supabase Postgres 연결 정보 (Project Settings → Database → Connection string)
# DATABASE_URL: Transaction pooler (포트 6543) — 앱이 평소 쿼리할 때 사용
# DIRECT_URL:   Direct connection (포트 5432) — prisma migrate 실행할 때만 사용
DATABASE_URL="postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# 서버 포트
PORT=4000

# JWT 서명 키 (반드시 배포 전 무작위 값으로 교체할 것)
# 생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
